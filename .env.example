# Runtime mode:
# - autonomous: Behavior OS in this repo
# - engine_proxy: god-mvp style bridge forwarding talk/god/exit to an external engine script
BRIDGE_MODE=autonomous

# Minecraft host config (both naming schemes supported)
MINECRAFT_HOST=localhost
MINECRAFT_PORT=25565
# Optional compatibility aliases used by minecraft-god-mvp docs:
# MC_HOST=127.0.0.1
# MC_PORT=25565

# Bot identity:
# autonomous defaults to MINECRAFT_USERNAME if no list is set
# engine_proxy defaults to BOT_NAMES=mara,eli,nox if no list is set
MINECRAFT_USERNAME=MaraBot
# BOT_NAMES=mara,eli,nox
# BOT_USERNAMES=MaraBot
# Optional for Microsoft auth:
# MINECRAFT_AUTH=microsoft
# MINECRAFT_PASSWORD=

# engine_proxy mode target process
# ENGINE_SCRIPT=../minecraft-god-mvp/src/index.js
# ENGINE_CWD=../minecraft-god-mvp
# CHAT_PREFIX=!

ADMIN_USERS=IntentJester8,YourNameHere

# Behavior loop and safety caps
BEHAVIOR_LOOP_MIN_MS=2000
BEHAVIOR_LOOP_MAX_MS=5000
ACTION_TIMEOUT_MS=12000

# Safety gates (keep false by default)
ALLOW_COMBAT=false
ALLOW_BLOCK_BREAKING=false
ALLOW_DIG=false
ALLOW_TRADING=true
ALLOW_CHEST_TAKE=false
CHAT_MIN_INTERVAL_MS=0

# Optional fixed points of interest
# CHURCH_X=0
# CHURCH_Y=64
# CHURCH_Z=0
# SHELTER_X=5
# SHELTER_Y=64
# SHELTER_Z=5

# Optional deterministic seed
SETTLEMENT_SEED=99173
